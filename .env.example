# s1-ingest-health-deployer credentials. Copy to .env and fill in. .env is git-ignored; never commit real tokens.

# ---- Required: Mgmt Console connect ----
# Tenant Mgmt Console URL, no trailing slash.
S1_CONSOLE_URL=https://your-tenant.sentinelone.net
# Mgmt Console -> Settings -> Users -> Service Users -> create one, copy the API token.
# This same token authenticates HEC ingest (there is no separate HEC token).
S1_CONSOLE_API_TOKEN=your-console-api-token

# ---- SDL: required for the review dashboard + live source discovery ----
# Region-specific SDL tenant URL.
SDL_XDR_URL=https://xdr.us1.sentinelone.net
# SDL -> API Keys -> Configuration Access Keys.
SDL_CONFIG_WRITE_KEY=your-sdl-config-write-key
SDL_CONFIG_READ_KEY=your-sdl-config-read-key

# ---- Alert ingest: required for the SILENT watchdog alert ----
# Region-specific HEC ingest host. Authenticates with S1_CONSOLE_API_TOKEN.
S1_HEC_INGEST_URL=https://ingest.us1.sentinelone.net

# ---- Optional: default deploy scope ----
# Account is auto-resolved from the tenant if left blank. Set a site to deploy there by default.
# S1_ACCOUNT and S1_SITE are accepted as aliases for the two IDs below.
S1_ACCOUNT_ID=
S1_DEFAULT_SITE_ID=
S1_DEFAULT_SITE_NAME=
# Naming prefix on every deployed artifact (baseline table, detections, flow, dashboard).
INGEST_PREFIX=INGEST
# The HA flows' "SentinelOne SDL" connection is chosen in the UI. There is no env var for it.

# ---- Optional: UI server (distinct default port from s1-ueba-deployer's 8799) ----
INGEST_PORT=8788
INGEST_HOST=127.0.0.1
# Extra allowed browser origins (comma-separated) for hosted setups; local use needs none.
UEBA_ALLOWED_ORIGINS=

# ---- Optional: network exposure (default is local/loopback only) ----
# Leave BIND_ALL unset for local use (in Docker, publish to the host loopback:
#   docker run -p 127.0.0.1:8888:8788 ...). To serve to other hosts, set INGEST_BIND_ALL=1 AND a
# strong INGEST_AUTH_TOKEN; the server refuses to start exposed without a token, and every /api
# call must carry it (open the UI at http://<host>:8888/?token=<secret>).
INGEST_BIND_ALL=
INGEST_AUTH_TOKEN=

# ---- Optional: debug logging (OFF unless set) ----
# INGEST_DEBUG=1 turns on a redacted, size-capped debug log (secrets are stripped before write).
INGEST_DEBUG=
# Server debug log path (used only when INGEST_DEBUG=1; default: ingest_debug.log in the workdir).
INGEST_LOG=
